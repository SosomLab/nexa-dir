<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Nexa.Controls.NexaFileGrid"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Nexa.Controls">

    <!-- 가상화 파일 그리드(도메인 비종속). 컬럼 헤더(Columns, 리사이즈 가능) + 본문(ItemTemplate 주입).
         컬럼 인스턴스를 공유하면 헤더·본문·좌/우가 같은 Width를 참조 → 리사이즈 동기화(A3/A4). -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" /> <!-- 컬럼 헤더 -->
            <RowDefinition Height="*" />    <!-- 본문 -->
        </Grid.RowDefinitions>

        <!-- 컬럼 헤더 행 (각 컬럼 우측에 리사이즈 핸들) -->
        <ItemsRepeater Grid.Row="0" ItemsSource="{x:Bind Columns, Mode=OneWay}">
            <ItemsRepeater.Layout>
                <StackLayout Orientation="Horizontal" />
            </ItemsRepeater.Layout>
            <ItemsRepeater.ItemTemplate>
                <DataTemplate x:DataType="local:NexaGridColumn">
                    <Grid Width="{x:Bind Width, Mode=OneWay}">
                        <Border Padding="6,3" BorderThickness="0,0,1,1" BorderBrush="#22FFFFFF">
                            <TextBlock Text="{x:Bind Header}" FontWeight="SemiBold" Opacity="0.85"
                                       TextTrimming="CharacterEllipsis" />
                        </Border>
                        <!-- 리사이즈 핸들(우측 6px). 드래그로 Width 조절 -->
                        <Border Width="6" HorizontalAlignment="Right" Background="Transparent"
                                ManipulationMode="TranslateX" ManipulationDelta="OnColumnResize"
                                Tag="{x:Bind}" />
                    </Grid>
                </DataTemplate>
            </ItemsRepeater.ItemTemplate>
        </ItemsRepeater>

        <!-- 본문(가상화) -->
        <ScrollViewer Grid.Row="1" VerticalScrollMode="Enabled" VerticalScrollBarVisibility="Auto">
            <ItemsRepeater x:Name="Repeater" ItemTemplate="{x:Bind ItemTemplate, Mode=OneWay}">
                <ItemsRepeater.Layout>
                    <StackLayout Orientation="Vertical" Spacing="2" />
                </ItemsRepeater.Layout>
            </ItemsRepeater>
        </ScrollViewer>
    </Grid>
</UserControl>
