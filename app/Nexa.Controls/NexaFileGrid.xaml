<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Nexa.Controls.NexaFileGrid"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Nexa.Controls"
    FontFamily="Segoe UI" FontSize="12">

    <!-- 가상화 파일 그리드(도메인 비종속). 컬럼 헤더(Columns, 리사이즈 가능) + 본문(ItemTemplate 주입).
         컬럼 인스턴스를 공유하면 헤더·본문·좌/우가 같은 Width를 참조 → 리사이즈 동기화(A3/A4). -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" /> <!-- 컬럼 헤더 -->
            <RowDefinition Height="*" />    <!-- 본문 -->
        </Grid.RowDefinitions>

        <!-- 컬럼 헤더 행: 전폭 헤더 바(HeaderBackground, 설정에서 변경 가능) + 컬럼별 셀(우측 리사이즈 핸들) -->
        <Grid Grid.Row="0">
            <!-- 헤더 바 배경 — 본문과 다른 색으로 구분. HeaderBackground DP 바인딩(설정 오버라이드) -->
            <Border Background="{x:Bind HeaderBackground, Mode=OneWay}"
                    BorderBrush="#33808080" BorderThickness="0,0,0,1" />
            <!-- 헤더도 가로 스크롤(스크롤바 숨김, 클리핑용) — 본문 가로 오프셋과 양방향 동기(코드) -->
            <ScrollViewer x:Name="HeaderScroll" HorizontalScrollMode="Enabled" HorizontalScrollBarVisibility="Hidden"
                          VerticalScrollMode="Disabled" VerticalScrollBarVisibility="Disabled" IsTabStop="False">
            <!-- 헤더는 패널별 HeaderCell 래퍼로 렌더(정렬 표시는 패널별, 너비는 공유 컬럼 바인딩=좌/우 동기) -->
            <ItemsRepeater x:Name="HeaderRepeater">
                <ItemsRepeater.Layout>
                    <StackLayout Orientation="Horizontal" />
                </ItemsRepeater.Layout>
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="local:HeaderCell">
                        <Grid Width="{x:Bind Column.Width, Mode=OneWay}">
                            <!-- 컬럼 셀(구분선만, 배경은 전폭 헤더 바가 담당). 클릭=3상태 정렬(▲/▼) -->
                            <Border Padding="6,2" BorderThickness="0,0,1,0" BorderBrush="#33808080"
                                    Background="Transparent" Tag="{x:Bind}" Tapped="OnHeaderTapped">
                                <StackPanel Orientation="Horizontal" Spacing="2">
                                    <!-- 정렬 화살표(▲/▼) — 컬럼명 앞. 정렬 없으면 접힘 -->
                                    <TextBlock Text="{x:Bind Glyph, Mode=OneWay}" Visibility="{x:Bind GlyphVisibility, Mode=OneWay}"
                                               FontSize="9" Opacity="0.85" VerticalAlignment="Center" />
                                    <TextBlock Text="{x:Bind Column.Header}" Opacity="0.9"
                                               FontWeight="{x:Bind TextWeight, Mode=OneWay}"
                                               FontStyle="{x:Bind TextStyle, Mode=OneWay}"
                                               TextTrimming="CharacterEllipsis" />
                                    <!-- 정렬 순번 원문자(①②③) — 컬럼명 뒤. 정렬 없으면 접힘 -->
                                    <TextBlock Text="{x:Bind OrderText, Mode=OneWay}" Visibility="{x:Bind OrderVisibility, Mode=OneWay}"
                                               FontSize="10" Opacity="0.8" VerticalAlignment="Center" />
                                </StackPanel>
                            </Border>
                            <!-- 리사이즈 핸들(우측 8px). 오버 시 SizeWestEast 커서(ColumnResizeGrip). PointerMove 캡처로 Width 조절 -->
                            <local:ColumnResizeGrip Width="8" HorizontalAlignment="Right" Background="Transparent"
                                    PointerPressed="OnResizeStart" PointerMoved="OnResizeMove"
                                    PointerReleased="OnResizeEnd" PointerCanceled="OnResizeEnd"
                                    Tag="{x:Bind Column}" />
                        </Grid>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>
            </ScrollViewer>
        </Grid>

        <!-- 본문(가상화). 드래그 중 가장자리 근처면 자동 스크롤(AllowDrop + DragOver 타이머).
             Background=Transparent: 행 밖 빈 영역(행 우측·목록 아래)도 히트 가능 → 빈영역 클릭/러버밴드(B-4).
             가로 스크롤 Auto: 컬럼 총폭이 표시 영역을 벗어날 때만 스크롤바 표시(세로와 동일 규약) — 헤더와 동기. -->
        <Grid Grid.Row="1">
            <ScrollViewer x:Name="BodyScroll" Background="Transparent"
                          VerticalScrollMode="Enabled" VerticalScrollBarVisibility="Auto"
                          HorizontalScrollMode="Enabled" HorizontalScrollBarVisibility="Auto"
                          ViewChanged="OnBodyViewChanged"
                          AllowDrop="True" DragOver="OnBodyDragOver" DragLeave="OnBodyDragLeave" Drop="OnBodyDragEnd">
                <!-- 행 간 간격 0 + 행 템플릿 상단 -1px 겹침(Margin) — 인접 선택 행의 1px 테두리가 같은
                     픽셀에 그려져 경계가 1px(박스 4면 유지). Repeater 상단 1px 마진 = 첫 행 -1px 보정.
                     변경 시 EstimateRowStride(코드)의 겹침 가산도 함께 갱신할 것. -->
                <ItemsRepeater x:Name="Repeater" ItemTemplate="{x:Bind ItemTemplate, Mode=OneWay}" Margin="0,1,0,0">
                    <ItemsRepeater.Layout>
                        <StackLayout Orientation="Vertical" Spacing="0" />
                    </ItemsRepeater.Layout>
                </ItemsRepeater>
            </ScrollViewer>
            <!-- 러버밴드(마퀴) 선택 사각형 오버레이(B-4) — 뷰포트 좌표로 그림, 히트 불가 -->
            <Canvas x:Name="MarqueeLayer" IsHitTestVisible="False">
                <Rectangle x:Name="MarqueeRect" Visibility="Collapsed"
                           Fill="#3357A9FF" Stroke="#9957A9FF" StrokeThickness="1" />
            </Canvas>
        </Grid>
    </Grid>
</UserControl>
