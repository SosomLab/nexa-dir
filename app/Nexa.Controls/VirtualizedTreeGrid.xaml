<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Nexa.Controls.VirtualizedTreeGrid"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- 가상화 목록/트리 컨트롤(도메인 비종속) — ItemsRepeater 래핑. 행 표현은 ItemTemplate 주입.
         후속: 컬럼 헤더·리사이즈(IColumn/ICellValueProvider), 트리 depth·펼침(ADR-0002 §7). -->
    <ScrollViewer VerticalScrollMode="Enabled" VerticalScrollBarVisibility="Auto">
        <ItemsRepeater x:Name="Repeater" ItemTemplate="{x:Bind ItemTemplate, Mode=OneWay}">
            <ItemsRepeater.Layout>
                <StackLayout Orientation="Vertical" Spacing="2" />
            </ItemsRepeater.Layout>
        </ItemsRepeater>
    </ScrollViewer>
</UserControl>
