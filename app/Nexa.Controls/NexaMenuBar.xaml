<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Nexa.Controls.NexaMenuBar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- 초박형 커스텀 메뉴 바(도메인 비종속). 기본 MenuBar/MenuFlyout는 (1)초박형 불가(글자 잘림)
         (2)둥근 팝업+light-dismiss로 hover 전환 불가 → Button 헤더 + 경량 Popup(사각 Border)로 직접 구성.
         hover 전환 · ALT 토글/단축키 · 사각 클래식 모양 · 빠른 렌더를 모두 제어. -->
    <Grid>
        <Border Background="{x:Bind Background, Mode=OneWay}">
            <StackPanel x:Name="Host" Orientation="Horizontal" VerticalAlignment="Stretch" />
        </Border>

        <!-- 드롭다운(사각 Border, 그림자/둥근 모서리 없음 → 빠름). light-dismiss 미사용(hover 전환 위해).
             색은 호스트 앱 테마 토큰(NexaMenu*) — 다크에서 밝은 회색 텍스트/약간 밝은 바탕(VS Code식).
             Popup 콘텐츠는 루트 RequestedTheme를 상속하지 않으므로 OpenMenu가 ActualTheme를 지정. -->
        <Popup x:Name="MenuPopup" IsLightDismissEnabled="False">
            <Border x:Name="PopupBorder" Background="{ThemeResource NexaMenuPopupBackgroundBrush}"
                    BorderBrush="{ThemeResource NexaMenuPopupBorderBrush}" BorderThickness="1">
                <StackPanel x:Name="ItemsHost" Orientation="Vertical" MinWidth="180" Padding="0,2" />
            </Border>
        </Popup>
    </Grid>
</UserControl>
