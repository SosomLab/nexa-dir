<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="Nexa.App.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>
            <!-- Nexa Dir 기본 폰트 = Segoe UI. 아이콘 폰트(Segoe MDL2 Assets)는 명시 지정이라 영향 없음.
                 · ContentControlThemeFontFamily → Button 등 컨트롤 기본 폰트.
                 · 영역별 텍스트 폰트(메뉴/경로/상태바/파일 목록/터미널/하단 정보)는 설정(PREF-3)에서
                   MainWindow.ApplyFonts가 영역 루트 컨트롤에 지정 → 하위 TextBlock이 상속.
                   (암시적 TextBlock Style로 FontFamily를 주면 Style이 상속값을 이겨 설정 폰트가 무시되므로 금지.) -->
            <x:String x:Key="ContentControlThemeFontFamily">Segoe UI</x:String>

            <!-- 플랫(고전) 컨텍스트 메뉴 프레젠터 — 사각·패널 배경·1px 테두리(둥근 아크릴 기본 룩 대체).
                 코드에서 MenuFlyout.MenuFlyoutPresenterStyle로 지정(MainWindow.FlatMenu). -->
            <Style x:Key="NexaMenuPresenterStyle" TargetType="MenuFlyoutPresenter">
                <Setter Property="CornerRadius" Value="0" />
                <Setter Property="Background" Value="{ThemeResource NexaPanelBackgroundBrush}" />
                <Setter Property="BorderBrush" Value="{ThemeResource NexaBorderBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Padding" Value="0,2" />
                <Setter Property="MinWidth" Value="200" />
            </Style>

            <!-- ── Nexa 시맨틱 테마 토큰(docs/39) — 컴포넌트는 {ThemeResource Nexa*Brush}만 참조.
                 라이트/다크는 RequestedTheme(설정 Theme.Mode)로 전환. 값 변경은 여기 한 곳. ── -->
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <!-- 메뉴 바 드롭다운(NexaMenuBar) — 고전 라이트 팝업 -->
                    <SolidColorBrush x:Key="NexaMenuPopupBackgroundBrush" Color="#F6F6F6" />
                    <SolidColorBrush x:Key="NexaMenuPopupBorderBrush" Color="#9A9A9A" />
                    <SolidColorBrush x:Key="NexaMenuTextBrush" Color="#1A1A1A" />
                    <SolidColorBrush x:Key="NexaMenuHoverBrush" Color="#CCE4F7" />
                    <SolidColorBrush x:Key="NexaWindowBackgroundBrush" Color="#F6F7F9" />
                    <SolidColorBrush x:Key="NexaChromeBackgroundBrush" Color="#EEF1F5" />
                    <SolidColorBrush x:Key="NexaPanelBackgroundBrush" Color="#FFFFFF" />
                    <SolidColorBrush x:Key="NexaTabBarBackgroundBrush" Color="#E6EAF0" />
                    <SolidColorBrush x:Key="NexaHeaderBackgroundBrush" Color="#E9ECF1" />
                    <SolidColorBrush x:Key="NexaFieldBackgroundBrush" Color="#FFFFFF" />
                    <SolidColorBrush x:Key="NexaBottomDockBackgroundBrush" Color="#F1F3F6" />
                    <SolidColorBrush x:Key="NexaStatusBarBackgroundBrush" Color="#EEF1F5" />
                    <SolidColorBrush x:Key="NexaBorderBrush" Color="#D5DAE1" />
                    <SolidColorBrush x:Key="NexaAccentBrush" Color="#3D8BFF" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <!-- 메뉴 바 드롭다운 — VS Code식: 크롬보다 조금 밝은 바탕 + 밝은 회색 텍스트 -->
                    <SolidColorBrush x:Key="NexaMenuPopupBackgroundBrush" Color="#262B33" />
                    <SolidColorBrush x:Key="NexaMenuPopupBorderBrush" Color="#454B55" />
                    <SolidColorBrush x:Key="NexaMenuTextBrush" Color="#CFD2D6" />
                    <SolidColorBrush x:Key="NexaMenuHoverBrush" Color="#3A414C" />
                    <SolidColorBrush x:Key="NexaWindowBackgroundBrush" Color="#14161A" />
                    <SolidColorBrush x:Key="NexaChromeBackgroundBrush" Color="#1E2228" />
                    <SolidColorBrush x:Key="NexaPanelBackgroundBrush" Color="#191C21" />
                    <SolidColorBrush x:Key="NexaTabBarBackgroundBrush" Color="#232830" />
                    <SolidColorBrush x:Key="NexaHeaderBackgroundBrush" Color="#262B33" />
                    <SolidColorBrush x:Key="NexaFieldBackgroundBrush" Color="#262B33" />
                    <SolidColorBrush x:Key="NexaBottomDockBackgroundBrush" Color="#1B1F25" />
                    <SolidColorBrush x:Key="NexaStatusBarBackgroundBrush" Color="#1E2228" />
                    <SolidColorBrush x:Key="NexaBorderBrush" Color="#363C46" />
                    <SolidColorBrush x:Key="NexaAccentBrush" Color="#3D8BFF" />
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
