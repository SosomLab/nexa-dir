<Window
    x:Class="Nexa.App.TransferProgressWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:loc="using:Nexa.App">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

        <!-- 진행 표시 -->
        <Grid Padding="14,12" RowSpacing="6">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- 제목·상태 텍스트는 코드(ctor/Complete)가 Loc로 설정 -->
            <TextBlock x:Name="TitleText" Grid.Row="0" FontSize="13" FontWeight="SemiBold" Text=""
                       TextTrimming="CharacterEllipsis" />
            <TextBlock x:Name="DetailText" Grid.Row="1" FontSize="12" Opacity="0.7" TextTrimming="CharacterEllipsis" Text="" />
            <TextBlock x:Name="PercentText" Grid.Row="2" FontSize="18" Margin="0,2,0,0" Text="0%" />
            <ProgressBar x:Name="Bar" Grid.Row="3" Minimum="0" Height="6" Margin="0,2,0,0" />

            <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,4,0,0">
                <Button x:Name="CancelBtn" Content="{loc:Loc Key=transfer.cancel}" Click="OnCancel"
                        FontSize="12" Padding="12,4" MinWidth="0" MinHeight="0" />
                <Button x:Name="CloseBtn" Content="{loc:Loc Key=transfer.close}" IsEnabled="False" Click="OnClose"
                        FontSize="12" Padding="12,4" MinWidth="0" MinHeight="0"
                        Style="{StaticResource AccentButtonStyle}" />
            </StackPanel>
        </Grid>

        <!-- 덮어쓰기 확인 프롬프트(창 안에 직접 표시 — ContentDialog XamlRoot 문제 회피) -->
        <Grid x:Name="PromptOverlay" Visibility="Collapsed" Padding="14"
              Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
            <StackPanel VerticalAlignment="Center" Spacing="12">
                <TextBlock x:Name="PromptTitle" FontSize="13" FontWeight="SemiBold" Text="{loc:Loc Key=overwrite.title}" />
                <TextBlock x:Name="PromptText" FontSize="12" TextWrapping="Wrap" Text="" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="6">
                    <Button x:Name="OwYes" Content="{loc:Loc Key=overwrite.yes}" Click="OnOwYes"
                            FontSize="12" Padding="10,4" MinWidth="0" MinHeight="0"
                            Style="{StaticResource AccentButtonStyle}" />
                    <Button x:Name="OwAll" Content="{loc:Loc Key=overwrite.yesAll}" Click="OnOwAll"
                            FontSize="12" Padding="10,4" MinWidth="0" MinHeight="0" />
                    <Button x:Name="OwNo" Content="{loc:Loc Key=overwrite.skip}" Click="OnOwNo"
                            FontSize="12" Padding="10,4" MinWidth="0" MinHeight="0" />
                    <Button x:Name="OwCancel" Content="{loc:Loc Key=transfer.cancel}" Click="OnOwCancel"
                            FontSize="12" Padding="10,4" MinWidth="0" MinHeight="0" />
                </StackPanel>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
