<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Nexa.App.PreferencesWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- 통합 설정 창(docs/40 PREF-1) — VS Code식: 좌측(검색 + 카테고리 트리) + 우측 편집기.
         검색은 좌측 트리(그룹 필터)와 우측 항목(제목/설명 일치)을 함께 거른다.
         트리/항목은 코드(카테고리·설정 레지스트리)에서 Loc로 구성. 변경은 라이브 적용 + settings.json 저장. -->
    <Grid Background="{ThemeResource NexaWindowBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{ThemeResource NexaChromeBackgroundBrush}"
                BorderBrush="{ThemeResource NexaBorderBrush}" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />  <!-- 0 설정 검색 -->
                    <RowDefinition Height="*" />     <!-- 1 카테고리 트리 -->
                </Grid.RowDefinitions>
                <AutoSuggestBox x:Name="SearchBox" Grid.Row="0" QueryIcon="Find" Margin="8,8,8,4"
                                TextChanged="OnSearchTextChanged" />
                <!-- 카테고리 트리(구성요소별) — 코드에서 Loc로 채움. 검색 중엔 일치 그룹만 -->
                <TreeView x:Name="NavTree" Grid.Row="1" SelectionMode="Single" CanDragItems="False" CanReorderItems="False"
                          ItemInvoked="OnNavInvoked" Padding="4,4" />
            </Grid>
        </Border>

        <ScrollViewer Grid.Column="1" Padding="20">
            <StackPanel x:Name="PageHost" Spacing="10" HorizontalAlignment="Stretch" />
        </ScrollViewer>
    </Grid>
</Window>
