<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Nexa.App.PreferencesWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- 통합 설정 창(docs/40 PREF-1) — VS Code식: 상단 설정 검색 + 좌 카테고리 트리 + 우 편집기.
         트리/항목은 코드(카테고리·설정 레지스트리)에서 Loc로 구성. 변경은 라이브 적용 + settings.json 저장. -->
    <Grid Background="{ThemeResource NexaWindowBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />  <!-- 0 검색 -->
            <RowDefinition Height="*" />     <!-- 1 트리 + 편집기 -->
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{ThemeResource NexaChromeBackgroundBrush}"
                BorderBrush="{ThemeResource NexaBorderBrush}" BorderThickness="0,0,0,1" Padding="12,10">
            <AutoSuggestBox x:Name="SearchBox" QueryIcon="Find" TextChanged="OnSearchTextChanged" />
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{ThemeResource NexaChromeBackgroundBrush}"
                    BorderBrush="{ThemeResource NexaBorderBrush}" BorderThickness="0,0,1,0">
                <!-- 카테고리 트리(구성요소별) — 코드에서 Loc로 채움 -->
                <TreeView x:Name="NavTree" SelectionMode="Single" CanDragItems="False" CanReorderItems="False"
                          ItemInvoked="OnNavInvoked" Padding="4,8" />
            </Border>

            <ScrollViewer Grid.Column="1" Padding="20">
                <StackPanel x:Name="PageHost" Spacing="10" HorizontalAlignment="Stretch" />
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
