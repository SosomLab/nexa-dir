<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Nexa.App.Terminal.TerminalView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    IsTabStop="True"
    KeyDown="OnKeyDown"
    CharacterReceived="OnCharacterReceived"
    GotFocus="OnGotFocus"
    LostFocus="OnLostFocus">

    <Grid Background="#0C0F12">
        <!-- 세로 패딩 0: 항상 최하단 스크롤이라 상단 패딩만큼 첫 줄이 잘려 보이던 문제 방지 -->
        <ScrollViewer x:Name="Scroll" Padding="6,0" IsTabStop="False"
                      VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                      VerticalScrollMode="Enabled" HorizontalScrollMode="Enabled">
            <!-- 셀 그리드(LinesPanel) 위에 선택(SelLayer)·캐럿(CaretLayer) 오버레이를 겹쳐 렌더 — 함께 스크롤 -->
            <Grid>
                <!-- VtScreen 셀 그리드 렌더 — 라인을 Canvas에 index×LineH 절대 배치.
                     (StackPanel 누적 배치는 UseLayoutRounding이 줄 높이를 px로 반올림해 행당 ~0.45px씩
                      오버레이(캐럿/선택)와 어긋남이 누적됐음 — 절대 배치는 개별 반올림뿐, 비누적) -->
                <!-- 명시 Width/Height + 기본 Stretch 정렬은 가운데 배치가 됨 → 반드시 Left/Top 고정 -->
                <Canvas x:Name="LinesPanel" HorizontalAlignment="Left" VerticalAlignment="Top" />
                <!-- 마우스 드래그 선택 하이라이트(복사용) -->
                <Canvas x:Name="SelLayer" IsHitTestVisible="False" />
                <Canvas x:Name="CaretLayer" IsHitTestVisible="False">
                    <Border x:Name="Caret" Visibility="Collapsed" />
                </Canvas>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
