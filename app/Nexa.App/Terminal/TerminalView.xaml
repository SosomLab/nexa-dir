<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Nexa.App.Terminal.TerminalView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    IsTabStop="True"
    KeyDown="OnKeyDown"
    CharacterReceived="OnCharacterReceived"
    PointerPressed="OnPointerPressed">

    <Grid Background="#0C0F12">
        <ScrollViewer x:Name="Scroll" Padding="6,4"
                      VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                      VerticalScrollMode="Enabled" HorizontalScrollMode="Enabled">
            <TextBlock x:Name="OutputText" FontFamily="Consolas" FontSize="12" Foreground="#E6E6E6"
                       TextWrapping="NoWrap" IsTextSelectionEnabled="True" />
        </ScrollViewer>
    </Grid>
</UserControl>
