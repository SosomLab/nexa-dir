<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Nexa.App.Terminal.TerminalView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    IsTabStop="True"
    KeyDown="OnKeyDown"
    CharacterReceived="OnCharacterReceived"
    GotFocus="OnGotFocus"
    LostFocus="OnLostFocus">

    <Grid Background="#0C0F12">
        <!-- 세로 패딩 0: 항상 최하단 스크롤이라 상단 패딩만큼 첫 줄이 잘려 보이던 문제 방지 -->
        <ScrollViewer x:Name="Scroll" Padding="6,0" IsTabStop="False"
                      VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                      VerticalScrollMode="Enabled" HorizontalScrollMode="Enabled">
            <!-- 셀 그리드(LinesPanel) 위에 캐럿(커서) 오버레이(CaretLayer)를 겹쳐 렌더 — 함께 스크롤 -->
            <Grid>
                <!-- VtScreen 셀 그리드를 색과 함께 렌더(라인=가로 StackPanel of 색 runs) -->
                <StackPanel x:Name="LinesPanel" />
                <Canvas x:Name="CaretLayer" IsHitTestVisible="False">
                    <Border x:Name="Caret" Visibility="Collapsed" />
                </Canvas>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
