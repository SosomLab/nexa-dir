<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Nexa.App.BottomDockView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:loc="using:Nexa.App">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 콘텐츠 종류 선택(정보/미리보기/Hex/터미널) — 라디오식 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="2" Padding="6,4,6,2">
            <ToggleButton x:Name="KindInfo" Content="{loc:Loc Key=dock.info}" Tag="Info" IsChecked="True" Click="OnKindClick"
                          FontSize="12" Padding="8,2" MinWidth="0" MinHeight="0" />
            <ToggleButton x:Name="KindPreview" Content="{loc:Loc Key=dock.preview}" Tag="Preview" Click="OnKindClick"
                          FontSize="12" Padding="8,2" MinWidth="0" MinHeight="0" />
            <ToggleButton x:Name="KindHex" Content="Hex" Tag="Hex" Click="OnKindClick"
                          FontSize="12" Padding="8,2" MinWidth="0" MinHeight="0" />
            <ToggleButton x:Name="KindTerminal" Content="{loc:Loc Key=dock.terminal}" Tag="Terminal" Click="OnKindClick"
                          FontSize="12" Padding="8,2" MinWidth="0" MinHeight="0" />
            <!-- 터미널 위치 이동(정사각, 터미널 토글에 밀착) — 이 도크 패널의 현재 탭 폴더로 cd -->
            <Button x:Name="TerminalCdBtn" Click="OnTerminalCd" Margin="-2,0,0,0"
                    Width="24" Height="24" Padding="0" MinWidth="0" MinHeight="0" VerticalAlignment="Center"
                    ToolTipService.ToolTip="{loc:Loc Key=toolbar.terminalCd}">
                <FontIcon Glyph="&#xE72A;" FontSize="12" />
            </Button>
        </StackPanel>

        <!-- 콘텐츠(종류별 스왑) — 텍스트(정보/Hex/터미널 placeholder) + 미리보기 요소 호스트 -->
        <Grid Grid.Row="1">
            <ScrollViewer x:Name="TextScroll" Padding="8,2,8,6" HorizontalScrollMode="Auto" HorizontalScrollBarVisibility="Auto">
                <TextBlock x:Name="ContentText" FontSize="12" Opacity="0.8" TextWrapping="Wrap"
                           IsTextSelectionEnabled="True" />
            </ScrollViewer>
            <!-- 미리보기(BP-2): 공급자가 만든 FrameworkElement를 여기 얹는다(표준 표시 영역) -->
            <Border x:Name="PreviewHost" Padding="4" Visibility="Collapsed" />
            <!-- 터미널(BP-T): lazy — 터미널 탭이 처음 활성화될 때만 TerminalView 생성/세션 시작 -->
            <Border x:Name="TerminalHost" Visibility="Collapsed" />
        </Grid>
    </Grid>
</UserControl>
