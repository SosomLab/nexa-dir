<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Nexa.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Nexa.App"
    xmlns:ctk="using:CommunityToolkit.WinUI.Controls"
    xmlns:ctrls="using:Nexa.Controls"
    Title="Nexa Dir">


    <!--
      레이아웃 골격(docs/20). 초안: 영역마다 뚜렷한 배경색으로 구분(촌스러워도 식별 우선).
      좌↔우 패널·메인↔하단 GridSplitter 크기 조절. 상태바 토글로 런처/우패널/하단/하단분리.
      하단 도킹: 기본 좌/우 분리(각 패널용 정보·터미널) → 터미널 활성 시 좌·우 2개.
      좌 패널 콘텐츠에 실제 디렉터리 목록(F4/F5) 보존.
    -->
    <Grid x:Name="RootGrid">
        <Grid.Resources>
            <!-- 좌/우 패널이 공유하는 컬럼 인스턴스 → 리사이즈 시 헤더·본문·양쪽 패널 동시 반영(A3/A4·요구4) -->
            <ctrls:NexaGridColumn x:Key="ColName" Header="이름" Key="name" Width="280" />
            <ctrls:NexaGridColumn x:Key="ColDate" Header="수정한 날짜" Key="modified" Width="120" />
            <ctrls:NexaGridColumn x:Key="ColKind" Header="종류" Key="kind" Width="90" />
            <ctrls:NexaGridColumn x:Key="ColSize" Header="크기" Key="size" Width="90" />
            <!-- 작은 네비 버튼(이전/다음/상위) — 아이콘 위주, 컴팩트 -->
            <Style x:Key="NavBtnStyle" TargetType="Button">
                <Setter Property="Width" Value="22" />
                <Setter Property="Height" Value="22" />
                <Setter Property="MinWidth" Value="0" />
                <Setter Property="MinHeight" Value="0" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
                <Setter Property="FontSize" Value="11" />
            </Style>
        </Grid.Resources>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />  <!-- 0 메뉴 바 -->
            <RowDefinition Height="Auto" />  <!-- 1 도구 모음 -->
            <RowDefinition Height="Auto" />  <!-- 2 퀵 런처 바 -->
            <RowDefinition Height="*" MinHeight="120" /> <!-- 3 메인 영역 -->
            <RowDefinition x:Name="TermSplitterRow" Height="Auto" /> <!-- 4 상하 splitter -->
            <RowDefinition x:Name="TermRow" Height="180" MinHeight="80" />  <!-- 5 하단 도킹(정보/터미널) · 세로 최소 -->
            <RowDefinition Height="Auto" />  <!-- 6 상태바 -->
        </Grid.RowDefinitions>

        <!-- 0 · 메뉴 바 (주황) — 커스텀 NexaMenuBar(초박형 18px/폰트9, 기본 MenuBar 한계 우회) -->
        <ctrls:NexaMenuBar Grid.Row="0" Background="#33FFA500" MenuHeight="18" FontSize="12" VerticalAlignment="Top">
            <ctrls:NexaMenuBar.Menus>
                <ctrls:NexaMenu Header="파일(F)">
                    <ctrls:NexaMenuEntry Text="새 탭" />
                    <ctrls:NexaMenuEntry Text="새 창" />
                    <ctrls:NexaMenuEntry Text="종료" />
                </ctrls:NexaMenu>
                <ctrls:NexaMenu Header="선택(M)">
                    <ctrls:NexaMenuEntry Text="모두 선택" />
                    <ctrls:NexaMenuEntry Text="선택 해제" />
                </ctrls:NexaMenu>
                <ctrls:NexaMenu Header="명령(C)">
                    <ctrls:NexaMenuEntry Text="복사" />
                    <ctrls:NexaMenuEntry Text="이동" />
                    <ctrls:NexaMenuEntry Text="삭제" />
                </ctrls:NexaMenu>
                <ctrls:NexaMenu Header="네트워크(N)" />
                <ctrls:NexaMenu Header="탭(T)" />
                <ctrls:NexaMenu Header="즐겨찾기(A)" />
                <ctrls:NexaMenu Header="표시(S)">
                    <ctrls:NexaMenuEntry Text="아이콘" />
                    <ctrls:NexaMenuEntry Text="목록" />
                    <ctrls:NexaMenuEntry Text="컬럼" />
                </ctrls:NexaMenu>
                <ctrls:NexaMenu Header="구성(O)" />
                <ctrls:NexaMenu Header="도움말(H)">
                    <ctrls:NexaMenuEntry Text="정보" />
                </ctrls:NexaMenu>
            </ctrls:NexaMenuBar.Menus>
        </ctrls:NexaMenuBar>

        <!-- 1 · 도구 모음 (파랑) -->
        <Border Grid.Row="1" Background="#334488DD" Padding="6,4">
            <StackPanel Orientation="Horizontal" Spacing="4">
                <Button Content="&#xE72B;" FontFamily="Segoe MDL2 Assets" ToolTipService.ToolTip="뒤로" />
                <Button Content="&#xE72A;" FontFamily="Segoe MDL2 Assets" ToolTipService.ToolTip="앞으로" />
                <Button Content="&#xE74A;" FontFamily="Segoe MDL2 Assets" ToolTipService.ToolTip="위로" />
                <Button Content="&#xE72C;" FontFamily="Segoe MDL2 Assets" ToolTipService.ToolTip="새로고침" />
                <AppBarSeparator />
                <Button Content="아이콘" /><Button Content="목록" /><Button Content="컬럼" /><Button Content="갤러리" />
                <TextBlock Text="도구 모음 (placeholder · 16×16 기본)" Opacity="0.6" VerticalAlignment="Center" Margin="8,0,0,0" />
            </StackPanel>
        </Border>

        <!-- 2 · 퀵 런처 바 (초록) -->
        <Border x:Name="LauncherBar" Grid.Row="2" Background="#3344CC66" Padding="6,4">
            <StackPanel Orientation="Horizontal" Spacing="6">
                <Button Content="cmd" /><Button Content="pwsh" /><Button Content="WT" />
                <AppBarSeparator />
                <Button Content="VSCode" /><Button Content="＋" />
                <TextBlock Text="퀵 런처 바 (placeholder)" Opacity="0.6" VerticalAlignment="Center" Margin="8,0,0,0" />
            </StackPanel>
        </Border>

        <!-- 3 · 메인 영역 (좌/우 듀얼 패널 + splitter) -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <!-- 기본 좌/우 동일 크기(50:50) — 둘 다 star -->
                <ColumnDefinition x:Name="LeftCol" Width="*" MinWidth="160" />
                <ColumnDefinition x:Name="SplitterCol" Width="Auto" />
                <ColumnDefinition x:Name="RightCol" Width="*" MinWidth="160" />
            </Grid.ColumnDefinitions>

            <!-- 좌 패널 (주) — 파란 틴트. ActualWidth = 좌/우 분리선 위치(스냅 계산용) -->
            <Border x:Name="LeftPaneRoot" Grid.Column="0" Background="#22338ADF"
                    SizeChanged="OnTopSplitSizeChanged">
                <Grid RowSpacing="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" /> <!-- 탭 바 -->
                        <RowDefinition Height="Auto" /> <!-- 네비 바 -->
                        <RowDefinition Height="Auto" /> <!-- 헤더 -->
                        <RowDefinition Height="*" />    <!-- 목록 -->
                    </Grid.RowDefinitions>

                    <!-- 탭 바: 멀티라인·고정크기(UniformGridLayout). +버튼 없음 — 빈 영역 더블클릭으로 추가. 활성 탭 상단 하이라이트 줄. -->
                    <Border Grid.Row="0" Background="#3340A0FF" Padding="4,3" Tag="L"
                            Tapped="OnTabBarTapped" DoubleTapped="OnTabBarDoubleTapped">
                        <ItemsRepeater x:Name="LeftTabs">
                            <ItemsRepeater.Layout>
                                <UniformGridLayout MinItemWidth="132" MinItemHeight="24"
                                                   MinRowSpacing="3" MinColumnSpacing="3" ItemsStretch="None" />
                            </ItemsRepeater.Layout>
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate x:DataType="local:PanelTab">
                                    <Border Background="{x:Bind TabBackground, Mode=OneWay}" CornerRadius="3"
                                            Tag="{x:Bind}" Tapped="OnTabTapped">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="2" />
                                                <RowDefinition Height="*" />
                                            </Grid.RowDefinitions>
                                            <Border Grid.Row="0" Background="#FF3D8BFF" CornerRadius="2,2,0,0"
                                                    Visibility="{x:Bind AccentVisibility, Mode=OneWay}" />
                                            <TextBlock Grid.Row="1" Text="{x:Bind Title, Mode=OneWay}"
                                                       TextTrimming="CharacterEllipsis" MaxLines="1"
                                                       Padding="8,1" VerticalAlignment="Center" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                    </Border>

                    <Border Grid.Row="1" Padding="6,3">
                        <StackPanel Orientation="Horizontal" Spacing="3">
                            <Button x:Name="BackBtnL" Style="{StaticResource NavBtnStyle}" Content="&#xE72B;" Tag="L" Click="OnNavBack" ToolTipService.ToolTip="뒤로" />
                            <Button x:Name="FwdBtnL" Style="{StaticResource NavBtnStyle}" Content="&#xE72A;" Tag="L" Click="OnNavForward" ToolTipService.ToolTip="앞으로" />
                            <Button x:Name="UpBtnL" Style="{StaticResource NavBtnStyle}" Content="&#xE74A;" Tag="L" Click="OnNavUp" ToolTipService.ToolTip="위로(상위 폴더)" />
                            <Border Background="#22FFFFFF" CornerRadius="4" Padding="8,4" VerticalAlignment="Center">
                                <TextBlock x:Name="PathText" Text="경로 바 (placeholder)" Opacity="0.8" />
                            </Border>
                        </StackPanel>
                    </Border>

                    <TextBlock Grid.Row="2" x:Name="DirHeader" Opacity="0.7" Margin="8,4" />

                    <ctrls:NexaFileGrid Grid.Row="3" x:Name="DirGrid" Margin="8,0" IsTabStop="True">
                        <ctrls:NexaFileGrid.ItemTemplate>
                            <DataTemplate x:DataType="local:DirItem">
                                <StackPanel Orientation="Horizontal" Padding="0,3"
                                            Background="{x:Bind RowBackground, Mode=OneWay}"
                                            BorderBrush="{x:Bind RowBorderBrush, Mode=OneWay}"
                                            BorderThickness="{x:Bind RowBorderThickness, Mode=OneWay}"
                                            Tag="{x:Bind}" PointerPressed="OnRowPointerPressed" DoubleTapped="OnRowDoubleTapped"
                                            PointerEntered="OnRowPointerEntered" PointerExited="OnRowPointerExited">
                                    <!-- 이름 셀: 들여쓰기 + 디스클로저(▶/▼) + 종류 아이콘 + 이름(폴더=굵게) -->
                                    <StackPanel Orientation="Horizontal" Width="{Binding Source={StaticResource ColName}, Path=Width, Mode=OneWay}">
                                        <Border Width="{x:Bind IndentWidth}" />
                                        <Border Width="16" Height="16" Background="Transparent" Tag="{x:Bind}" PointerPressed="OnToggleExpand" VerticalAlignment="Center">
                                            <FontIcon Glyph="{x:Bind ExpandGlyph, Mode=OneWay}" FontFamily="Segoe MDL2 Assets" FontSize="9" Opacity="0.8" />
                                        </Border>
                                        <!-- 실제 셸 아이콘(있으면) + 글리프 폴백 -->
                                        <Grid Width="16" Height="16" Margin="2,0,6,0" VerticalAlignment="Center">
                                            <FontIcon Glyph="{x:Bind IconGlyph}" Foreground="{x:Bind IconBrush}" FontFamily="Segoe MDL2 Assets" FontSize="14" Visibility="{x:Bind GlyphVisibility, Mode=OneWay}" />
                                            <Image Source="{x:Bind IconImage, Mode=OneWay}" Width="16" Height="16" Visibility="{x:Bind IconImageVisibility, Mode=OneWay}" />
                                        </Grid>
                                        <TextBlock Text="{x:Bind Name}" FontWeight="{x:Bind NameWeight}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                    </StackPanel>
                                    <TextBlock Width="{Binding Source={StaticResource ColDate}, Path=Width, Mode=OneWay}" Text="{x:Bind ModifiedLabel}" Opacity="0.6" Padding="6,0,0,0" VerticalAlignment="Center" />
                                    <TextBlock Width="{Binding Source={StaticResource ColKind}, Path=Width, Mode=OneWay}" Text="{x:Bind KindText}" Opacity="0.6" Padding="6,0,0,0" VerticalAlignment="Center" />
                                    <TextBlock Width="{Binding Source={StaticResource ColSize}, Path=Width, Mode=OneWay}" Text="{x:Bind SizeLabel}" Opacity="0.6" Padding="0,0,10,0" TextAlignment="Right" VerticalAlignment="Center" />
                                </StackPanel>
                            </DataTemplate>
                        </ctrls:NexaFileGrid.ItemTemplate>
                    </ctrls:NexaFileGrid>
                </Grid>
            </Border>

            <!-- 좌↔우 splitter (얇게 + 스냅: 중앙/하단 분리선 정렬) -->
            <ctk:GridSplitter x:Name="PanelSplitter" Grid.Column="1" Width="4" MinWidth="4" MaxWidth="4"
                              Padding="0" Background="#22FFFFFF" Foreground="Transparent"
                              ResizeBehavior="PreviousAndNext" ResizeDirection="Columns" />

            <!-- 우 패널 (듀얼) — 빨간 틴트. 좌 패널과 동일하게 파일 목록 표시 -->
            <Border x:Name="RightPanel" Grid.Column="2" Background="#22DD5555">
                <Grid RowSpacing="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" /> <!-- 탭 바 -->
                        <RowDefinition Height="Auto" /> <!-- 네비 바 -->
                        <RowDefinition Height="Auto" /> <!-- 헤더 -->
                        <RowDefinition Height="*" />    <!-- 목록 -->
                    </Grid.RowDefinitions>

                    <!-- 우 패널 탭 바(멀티라인·고정크기, 좌 패널과 동일 규칙) -->
                    <Border Grid.Row="0" Background="#33FF6060" Padding="4,3" Tag="R"
                            Tapped="OnTabBarTapped" DoubleTapped="OnTabBarDoubleTapped">
                        <ItemsRepeater x:Name="RightTabs">
                            <ItemsRepeater.Layout>
                                <UniformGridLayout MinItemWidth="132" MinItemHeight="24"
                                                   MinRowSpacing="3" MinColumnSpacing="3" ItemsStretch="None" />
                            </ItemsRepeater.Layout>
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate x:DataType="local:PanelTab">
                                    <Border Background="{x:Bind TabBackground, Mode=OneWay}" CornerRadius="3"
                                            Tag="{x:Bind}" Tapped="OnTabTapped">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="2" />
                                                <RowDefinition Height="*" />
                                            </Grid.RowDefinitions>
                                            <Border Grid.Row="0" Background="#FF3D8BFF" CornerRadius="2,2,0,0"
                                                    Visibility="{x:Bind AccentVisibility, Mode=OneWay}" />
                                            <TextBlock Grid.Row="1" Text="{x:Bind Title, Mode=OneWay}"
                                                       TextTrimming="CharacterEllipsis" MaxLines="1"
                                                       Padding="8,1" VerticalAlignment="Center" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                    </Border>

                    <Border Grid.Row="1" Padding="6,3">
                        <StackPanel Orientation="Horizontal" Spacing="3">
                            <Button x:Name="BackBtnR" Style="{StaticResource NavBtnStyle}" Content="&#xE72B;" Tag="R" Click="OnNavBack" ToolTipService.ToolTip="뒤로" />
                            <Button x:Name="FwdBtnR" Style="{StaticResource NavBtnStyle}" Content="&#xE72A;" Tag="R" Click="OnNavForward" ToolTipService.ToolTip="앞으로" />
                            <Button x:Name="UpBtnR" Style="{StaticResource NavBtnStyle}" Content="&#xE74A;" Tag="R" Click="OnNavUp" ToolTipService.ToolTip="위로(상위 폴더)" />
                            <Border Background="#22FFFFFF" CornerRadius="4" Padding="8,4" VerticalAlignment="Center">
                                <TextBlock x:Name="PathText2" Text="경로 바 (placeholder)" Opacity="0.8" />
                            </Border>
                        </StackPanel>
                    </Border>

                    <TextBlock Grid.Row="2" x:Name="DirHeader2" Opacity="0.7" Margin="8,4" />

                    <ctrls:NexaFileGrid Grid.Row="3" x:Name="DirGrid2" Margin="8,0" IsTabStop="True">
                        <ctrls:NexaFileGrid.ItemTemplate>
                            <DataTemplate x:DataType="local:DirItem">
                                <StackPanel Orientation="Horizontal" Padding="0,3"
                                            Background="{x:Bind RowBackground, Mode=OneWay}"
                                            BorderBrush="{x:Bind RowBorderBrush, Mode=OneWay}"
                                            BorderThickness="{x:Bind RowBorderThickness, Mode=OneWay}"
                                            Tag="{x:Bind}" PointerPressed="OnRowPointerPressed" DoubleTapped="OnRowDoubleTapped"
                                            PointerEntered="OnRowPointerEntered" PointerExited="OnRowPointerExited">
                                    <!-- 이름 셀: 들여쓰기 + 디스클로저(▶/▼) + 종류 아이콘 + 이름(폴더=굵게) -->
                                    <StackPanel Orientation="Horizontal" Width="{Binding Source={StaticResource ColName}, Path=Width, Mode=OneWay}">
                                        <Border Width="{x:Bind IndentWidth}" />
                                        <Border Width="16" Height="16" Background="Transparent" Tag="{x:Bind}" PointerPressed="OnToggleExpand" VerticalAlignment="Center">
                                            <FontIcon Glyph="{x:Bind ExpandGlyph, Mode=OneWay}" FontFamily="Segoe MDL2 Assets" FontSize="9" Opacity="0.8" />
                                        </Border>
                                        <!-- 실제 셸 아이콘(있으면) + 글리프 폴백 -->
                                        <Grid Width="16" Height="16" Margin="2,0,6,0" VerticalAlignment="Center">
                                            <FontIcon Glyph="{x:Bind IconGlyph}" Foreground="{x:Bind IconBrush}" FontFamily="Segoe MDL2 Assets" FontSize="14" Visibility="{x:Bind GlyphVisibility, Mode=OneWay}" />
                                            <Image Source="{x:Bind IconImage, Mode=OneWay}" Width="16" Height="16" Visibility="{x:Bind IconImageVisibility, Mode=OneWay}" />
                                        </Grid>
                                        <TextBlock Text="{x:Bind Name}" FontWeight="{x:Bind NameWeight}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                    </StackPanel>
                                    <TextBlock Width="{Binding Source={StaticResource ColDate}, Path=Width, Mode=OneWay}" Text="{x:Bind ModifiedLabel}" Opacity="0.6" Padding="6,0,0,0" VerticalAlignment="Center" />
                                    <TextBlock Width="{Binding Source={StaticResource ColKind}, Path=Width, Mode=OneWay}" Text="{x:Bind KindText}" Opacity="0.6" Padding="6,0,0,0" VerticalAlignment="Center" />
                                    <TextBlock Width="{Binding Source={StaticResource ColSize}, Path=Width, Mode=OneWay}" Text="{x:Bind SizeLabel}" Opacity="0.6" Padding="0,0,10,0" TextAlignment="Right" VerticalAlignment="Center" />
                                </StackPanel>
                            </DataTemplate>
                        </ctrls:NexaFileGrid.ItemTemplate>
                    </ctrls:NexaFileGrid>
                </Grid>
            </Border>
        </Grid>

        <!-- 4 · 메인↔하단 상하 splitter (얇게) -->
        <ctk:GridSplitter x:Name="TermSplitter" Grid.Row="4" Height="4" MinHeight="4" MaxHeight="4"
                          Padding="0" Background="#22FFFFFF" Foreground="Transparent"
                          ResizeBehavior="PreviousAndNext" ResizeDirection="Rows" />

        <!-- 5 · 하단 도킹 패널 — 좌/우 분리(기본). 각 패널용 정보·터미널(ConPTY 후속) -->
        <Grid x:Name="TerminalPanel" Grid.Row="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="BottomLeftCol" Width="*" MinWidth="160" />
                <ColumnDefinition x:Name="BottomSplitterCol" Width="Auto" />
                <ColumnDefinition x:Name="BottomRightCol" Width="*" MinWidth="160" />
            </Grid.ColumnDefinitions>

            <!-- 하단 좌 도킹 (청록) — ActualWidth = 하단 좌/우 분리선 위치(스냅 계산용) -->
            <Border x:Name="BottomLeftPaneRoot" Grid.Column="0" Background="#3322C0C0"
                    BorderBrush="#33000000" BorderThickness="0,1,0,0"
                    SizeChanged="OnBottomSplitSizeChanged">
                <StackPanel Padding="8" Spacing="4">
                    <TextBlock Text="좌 패널 — 정보/미리보기/Hex/터미널 (placeholder)" Opacity="0.75" />
                    <TextBlock Text="left> macbook@host ~/Documents %" FontFamily="Consolas" Opacity="0.55" />
                </StackPanel>
            </Border>

            <!-- 하단 좌↔우 splitter (얇게 + 스냅: 중앙/상단 분리선 정렬) -->
            <ctk:GridSplitter x:Name="BottomSplitter" Grid.Column="1" Width="4" MinWidth="4" MaxWidth="4"
                              Padding="0" Background="#22FFFFFF" Foreground="Transparent"
                              ResizeBehavior="PreviousAndNext" ResizeDirection="Columns" />

            <!-- 하단 우 도킹 (자주) -->
            <Border x:Name="BottomRightDock" Grid.Column="2" Background="#33CC55CC" BorderBrush="#33000000" BorderThickness="0,1,0,0">
                <StackPanel Padding="8" Spacing="4">
                    <TextBlock Text="우 패널 — 정보/미리보기/Hex/터미널 (placeholder)" Opacity="0.75" />
                    <TextBlock Text="right> macbook@host ~/Projects %" FontFamily="Consolas" Opacity="0.55" />
                </StackPanel>
            </Border>
        </Grid>

        <!-- 6 · 상태바 (회색) + 숨김/분리 토글 -->
        <Border Grid.Row="6" Background="#33888888" Padding="8,4">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <TextBlock x:Name="StatusText" Text="준비됨" Opacity="0.85" VerticalAlignment="Center" />
                <AppBarSeparator />
                <TextBlock Text="표시:" Opacity="0.6" VerticalAlignment="Center" />
                <ToggleButton x:Name="ToggleLauncherBtn" Content="런처" IsChecked="True" Click="OnToggleLauncher" />
                <ToggleButton x:Name="ToggleRightBtn" Content="우 패널" IsChecked="True" Click="OnToggleRightPanel" />
                <ToggleButton x:Name="ToggleTerminalBtn" Content="하단" IsChecked="True" Click="OnToggleTerminal" />
                <ToggleButton x:Name="ToggleBottomSplitBtn" Content="하단 좌/우 분리" IsChecked="True" Click="OnToggleBottomSplit" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
